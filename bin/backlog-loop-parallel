#!/usr/bin/env bash
# backlog-loop-parallel — fan out docs/backlog.md across N concurrent
# `claude -p` sessions. Each session claims one specific item (passed in),
# opens a worktree, ships a PR, and watches it to merge.
#
# Usage:  bin/backlog-loop-parallel [concurrency]   # default 3
#
# Trade-off vs bin/backlog-loop: items are worked in parallel, so two PRs
# will often race to edit docs/backlog.md. The prompt tells each session to
# rebase on that conflict (the bullet each PR deletes is disjoint, so the
# resolution is mechanical). Dependencies between items are NOT respected —
# don't use this if the top-of-backlog ordering is load-bearing.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BACKLOG="$REPO_ROOT/docs/backlog.md"
CONCURRENCY="${1:-3}"

cd "$REPO_ROOT"

# --- worker mode: invoked by xargs for each item ---------------------------
if [[ "${BACKLOG_LOOP_WORKER:-}" == "1" ]]; then
  item="$1"
  echo "=== worker start: $(printf '%s' "$item" | head -n1) ==="

  prompt=$(cat <<PROMPT
You are one parallel worker in an autonomous backlog fan-out. Other workers
are shipping other items concurrently. The item assigned to YOU is:

$item

Execute end-to-end without asking for confirmation:

1. EnterWorktree off main so you do not clash with sibling workers.
2. Read any docs the item references before designing the change.
3. Implement following CLAUDE.md: strict TDD, one logical change, deno lint
   clean, relevant test suites green.
4. In the SAME branch, edit docs/backlog.md and delete EXACTLY the bullet
   above — the \`- **...\` header plus every 2-space-indented continuation
   line. Leave other bullets untouched. Do not leave a double blank line.
5. Commit with Conventional Commits, push the branch, open a PR against main
   with \`gh pr create\` (Summary section only, no test plan), then
   \`gh pr merge --auto --squash\`.
6. Watch with \`gh pr checks --watch\`. If checks fail, fix and push again.
7. If auto-merge stalls on a docs/backlog.md conflict (another worker landed
   first), rebase onto origin/main, re-delete your bullet, force-push, and
   re-enable auto-merge. Do NOT touch bullets you were not assigned.
8. When the PR is merged, exit the worktree and end the session.

If investigation shows the item is obsolete, superseded, or infeasible, ship
a tiny PR that only removes your bullet, commit body explaining why. Same
auto-merge + watch flow.

Do NOT stop until your PR is merged.
PROMPT
)

  if ! claude -p "$prompt" --dangerously-skip-permissions </dev/null; then
    echo "!!! worker failed: $(printf '%s' "$item" | head -n1)" >&2
    exit 1
  fi
  exit 0
fi

# --- dispatcher ------------------------------------------------------------
git checkout main --quiet
git pull --ff-only origin main --quiet

items_file="$(mktemp)"
trap 'rm -f "$items_file"' EXIT

awk '
  /^## Open/        { in_open = 1; next }
  /^## / && in_open { in_open = 0 }
  !in_open          { next }
  /^- \*\*/ {
    if (buf != "") printf "%s%c", buf, 0
    buf = $0
    next
  }
  /^  / && buf != "" {
    buf = buf "\n" $0
    next
  }
  /^$/ { next }
  END {
    if (buf != "") printf "%s%c", buf, 0
  }
' "$BACKLOG" > "$items_file"

count=$(tr -cd '\0' < "$items_file" | wc -c | tr -d ' ')
if [[ "$count" == "0" ]]; then
  echo "No open backlog items. Done."
  exit 0
fi

echo "Dispatching $count items across $CONCURRENCY workers…"

BACKLOG_LOOP_WORKER=1 \
  xargs -0 -n 1 -P "$CONCURRENCY" "$0" < "$items_file"

echo "All workers finished."
