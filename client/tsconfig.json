{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@zone-blitz/shared": ["../packages/shared/mod.ts"],
      "@zone-blitz/server": ["../server/main.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src"]
}
