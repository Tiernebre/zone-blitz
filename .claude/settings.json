{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "deno fmt && git add -u",
            "timeout": 30,
            "statusMessage": "Formatting with deno fmt..."
          }
        ]
      }
    ]
  }
}
