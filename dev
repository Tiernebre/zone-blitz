#!/usr/bin/env bash
# Run Tailwind in watch mode alongside `./gradlew bootRun`.
# Ctrl-C stops both.
set -euo pipefail
set -m  # job control: each background pipeline gets its own process group

cd "$(dirname "$0")"

PORT=3000

BOLD=$'\033[1m'
DIM=$'\033[2m'
GREEN=$'\033[32m'
CYAN=$'\033[36m'
YELLOW=$'\033[33m'
RESET=$'\033[0m'

start_epoch=$(date +%s)
elapsed() {
	local now; now=$(date +%s)
	printf "%ds" "$((now - start_epoch))"
}

log() { printf "%s[dev %s]%s %s\n" "$DIM" "$(elapsed)" "$RESET" "$1"; }

printf "\n%s%s▶ Zone Blitz dev%s\n" "$BOLD" "$CYAN" "$RESET"
printf "%sGradle daemons take ~10-20s to warm up on first run, then bootRun adds another 15-30s before the app binds to :3000.%s\n" "$DIM" "$RESET"
printf "%sTailwind watch rebuilds CSS on template saves; Thymeleaf hot-reload (dev profile) picks up template edits without restart.%s\n" "$DIM" "$RESET"
printf "%s'classes' runs in continuous mode so Java edits recompile; Spring Boot devtools restarts the app when build/classes changes.%s\n\n" "$DIM" "$RESET"

prefix() {
	local tag=$1 color=$2
	while IFS= read -r line; do
		printf "%s%s[%s %s]%s %s\n" "$color" "$BOLD" "$tag" "$(elapsed)" "$RESET" "$line"
		case "$line" in
			*"Started "*"in "*"seconds"*)
				log "${GREEN}✔ bootRun ready — http://localhost:3000${RESET}"
				;;
			*"Done in "*)
				log "${GREEN}✔ tailwind initial build complete${RESET}"
				;;
		esac
	done
}

pids=()
cleanup() {
	trap - INT TERM EXIT
	log "${YELLOW}shutting down…${RESET}"

	# Kill the gradle client + pipeline readers we directly spawned.
	for pid in "${pids[@]}"; do
		# Resolve the process group id; fall back to pid if ps can't see it.
		local pgid
		pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)
		if [[ -n "$pgid" ]]; then
			kill -TERM "-$pgid" 2>/dev/null || true
		fi
		kill -TERM "$pid" 2>/dev/null || true
	done

	# The JVM is a child of the Gradle daemon, not us, so kill it by port.
	local holder
	holder=$(lsof -t -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
	if [[ -n "$holder" ]]; then
		log "${YELLOW}killing JVM on :$PORT (pid $holder)${RESET}"
		kill -TERM $holder 2>/dev/null || true
		# Give it half a second to exit gracefully, then hard-kill anything left.
		for _ in 1 2 3 4 5; do
			sleep 0.1
			holder=$(lsof -t -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
			[[ -z "$holder" ]] && break
		done
		[[ -n "$holder" ]] && kill -KILL $holder 2>/dev/null || true
	fi

	log "done."
	exit 0
}
trap cleanup INT TERM EXIT

log "starting postgres (docker compose)…"
if ! docker compose up -d --wait postgres 2>&1 | prefix "postgres" "$CYAN"; then
	log "${YELLOW}postgres failed to become healthy — aborting${RESET}"
	exit 1
fi
log "${GREEN}✔ postgres ready${RESET}"

tag_pids=()
tag_names=()

launch() {
	local tag=$1 color=$2
	shift 2
	"$@" 2>&1 | prefix "$tag" "$color" &
	local pid=$!
	pids+=("$pid")
	tag_pids+=("$pid")
	tag_names+=("$tag")
}

tag_for() {
	local pid=$1 i
	for i in "${!tag_pids[@]}"; do
		if [[ "${tag_pids[$i]}" == "$pid" ]]; then
			printf '%s' "${tag_names[$i]}"
			return
		fi
	done
	printf 'unknown'
}

log "starting tailwind watch…"
launch "tailwind" "$CYAN" ./gradlew --console=rich -t tailwindBuild

log "starting bootRun…"
launch "boot    " "$GREEN" ./gradlew --console=rich bootRun

log "starting classes --continuous…"
launch "compile " "$YELLOW" ./gradlew --console=rich -t classes -x generateJooq

# All three are long-running (bootRun, -t tailwindBuild, -t classes). If any
# exits — success or failure — something is wrong; report it and shut down.
# bash 3.2 lacks `wait -n`, so poll with `kill -0`.
while :; do
	for pid in "${tag_pids[@]}"; do
		if ! kill -0 "$pid" 2>/dev/null; then
			set +e
			wait "$pid"
			status=$?
			set -e
			exited_tag=$(tag_for "$pid")
			if [[ $status -eq 0 ]]; then
				log "${YELLOW}[$exited_tag] exited unexpectedly (status 0) — shutting down${RESET}"
			else
				log "${YELLOW}[$exited_tag] failed with status $status — shutting down${RESET}"
			fi
			exit $status
		fi
	done
	sleep 1
done
